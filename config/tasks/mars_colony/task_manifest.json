{
  "task_id": "mars_colony",
  "name": "Minerva Mars Colony",
  "version": "2.0",
  "description": "MITM Mars Colony task package containing DIK + environment/action/task context.",
  "default": true,
  "planner_defaults": {
    "planner_enabled": true,
    "planner_interval_steps": 24,
    "planner_interval_time": 20.0,
    "planner_trigger_mask": [
      "phase_transition",
      "new_dik_acquired",
      "contradiction_detected",
      "build_readiness_changed"
    ],
    "planner_timeout_seconds": 900.0,
    "planner_fallback_backend": "rule_brain",
    "planner_max_retries": 0,
    "explanation_mode": "never",
    "explanation_every_n_calls": 5,
    "explanation_probability": 0.1,
    "enable_planner_trace": true,
    "planner_trace_mode": "full",
    "planner_trace_max_chars": 12000,
    "enable_startup_llm_sanity": true,
    "startup_llm_sanity_timeout_seconds": 900.0,
    "startup_llm_sanity_max_sources": 2,
    "startup_llm_sanity_max_items_per_type": 3,
    "startup_llm_sanity_raw_response_max_chars": 4000,
    "startup_llm_sanity_artifact_name": "startup_llm_sanity.json",
    "enable_bootstrap_summary_reuse": true,
    "bootstrap_summary_max_chars": 280,
    "degraded_consecutive_failures_threshold": 24,
    "degraded_cooldown_seconds": 300.0,
    "degraded_step_interval_multiplier": 8.0,
    "sticky_backend_demotion_enabled": false,
    "high_latency_local_llm_mode": true,
    "high_latency_stale_result_grace_s": 1800.0,
    "startup_llm_sanity_completion_max_tokens": 24576,
    "planner_completion_max_tokens": 24576,
    "warmup_timeout_seconds": 600.0,
    "unrestricted_local_qwen_mode": true,
    "permissive_timeout_ceiling_s": 1800.0,
    "permissive_completion_ceiling_tokens": 32768
  },
  "agent_templates": {
    "mars_architect": {
      "role": "Architect",
      "label": "Architect",
      "accessible_packet_ids": [
        "Team_Info",
        "Architect_Info"
      ],
      "brain_config": {
        "plan_horizon": 3,
        "explanation_style": "concise"
      }
    },
    "mars_engineer": {
      "role": "Engineer",
      "label": "Engineer",
      "accessible_packet_ids": [
        "Team_Info",
        "Engineer_Info"
      ],
      "brain_config": {
        "plan_horizon": 3
      }
    },
    "mars_botanist": {
      "role": "Botanist",
      "label": "Botanist",
      "accessible_packet_ids": [
        "Team_Info",
        "Botanist_Info"
      ],
      "brain_config": {
        "plan_horizon": 3
      }
    }
  }
}
